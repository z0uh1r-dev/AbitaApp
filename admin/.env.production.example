APP_NAME=AbitaDash
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=abitadash
DB_USERNAME=abitadash
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# Optional: set these before running `php artisan db:seed` to control the
# initial passwords for the 3 seeded accounts instead of letting the Seeder
# auto-generate and print them once. Only used on first creation — has no
# effect if the account already exists. Remove after seeding.
# SUPER_ADMIN_INITIAL_PASSWORD=
# EMPLOYEE_ZOHAIR_INITIAL_PASSWORD=
# EMPLOYEE_HACHEM_INITIAL_PASSWORD=

VITE_APP_NAME="${APP_NAME}"
